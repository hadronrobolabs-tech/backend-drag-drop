# Server port (default: 3000)
PORT=3000

# MySQL — backend DB (custom_blocks, etc.). Set these on Hostinger under Environment Variables.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=drag_and_drop

# Optional: Arduino CLI path (for local compile/upload)
# ARDUINO_CLI_PATH=arduino-cli
# ARDUINO_HOME=~/Arduino

